{
  "expo": {
    "name": "MyMusic",
    "slug": "my-music",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "mymusic",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.personal.mymusic",
      "infoPlist": {
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "package": "com.personal.mymusic",
      "adaptiveIcon": {
        "backgroundColor": "#0f0f1a"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-av",
        { "microphonePermission": false }
      ]
    ]
  }
}
